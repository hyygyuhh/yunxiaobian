{
  "manifest_version": 3,
  "name": "网易云乐谱工具",
  "version": "1.2.3",
  "description": "网易云乐谱查询/上传/贡献工具，含云小编 xeapi 投票审核",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["cookies", "storage", "notifications", "scripting", "tabs"],
  "host_permissions": [
    "https://music.163.com/*",
    "https://*.music.163.com/*",
    "https://interface.music.163.com/*",
    "https://interface3.music.163.com/*",
    "https://*.163.com/*",
    "http://nosup-jd1.127.net/*",
    "http://localhost:3100/*",
    "http://127.0.0.1:3100/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "网易云乐谱工具",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["app/*", "api-shim.js", "favicon.png", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost:3100/*", "http://127.0.0.1:3100/*"],
      "js": ["content-local.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://music.163.com/*", "https://*.music.163.com/*"],
      "js": ["content-netease.js"],
      "run_at": "document_idle"
    }
  ]
}
